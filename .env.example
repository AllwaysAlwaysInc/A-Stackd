# A Stack'd backend configuration
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# Auth — REQUIRED in production. A dev default is used when unset in development.
JWT_SECRET=change-me-in-prod

# Storage — when set, the PostgreSQL store is used (and migrated on boot).
# Leave unset to use the in-memory seeded store for local/dev.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/astackd

# Security
CORS_ORIGIN=*
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
